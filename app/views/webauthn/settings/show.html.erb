<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Passkeys</h1>
  <p class="mt-4 text-gray-700">
    Passkeys let you sign in with your fingerprint, face, screen lock, or a security key —
    no password to remember. You can register more than one (e.g. a phone and a laptop).
  </p>

  <div class="mt-8">
    <% if @credentials.any? %>
      <ul class="divide-y divide-gray-200 border-y border-gray-200">
        <% @credentials.each do |credential| %>
          <li class="flex items-center justify-between py-4">
            <div>
              <p class="font-medium text-gray-900"><%= credential.nickname %></p>
              <p class="text-sm text-gray-500">
                Added <%= credential.created_at.to_date.to_fs(:long) %><%= " · last used #{credential.last_used_at.to_date.to_fs(:long)}" if credential.last_used_at %>
              </p>
            </div>
            <%= button_to "Remove", webauthn_credential_path(credential), method: :delete,
                  class: "rounded-md px-3 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium cursor-pointer" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500">You haven't registered any passkeys yet.</p>
    <% end %>
  </div>

  <div class="mt-8 border-t border-gray-200 pt-6"
       data-controller="webauthn-registration"
       data-webauthn-registration-options-url-value="<%= options_webauthn_credentials_path %>"
       data-webauthn-registration-callback-url-value="<%= webauthn_credentials_path %>">
    <h2 class="font-bold text-xl">Add a passkey</h2>
    <p class="mt-1 text-sm text-gray-500">Give it a name so you can tell your devices apart.</p>

    <p data-webauthn-registration-target="error" class="mt-3 text-red-500 font-medium"></p>

    <div class="my-4">
      <input type="text" data-webauthn-registration-target="nickname"
             placeholder="e.g. MacBook, iPhone, YubiKey"
             class="block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 w-full sm:w-80">
    </div>

    <button type="button"
            data-action="webauthn-registration#register"
            data-webauthn-registration-target="submit"
            class="rounded-lg px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer">
      Add a passkey
    </button>
  </div>
</div>
