<div class="mx-auto max-w-2xl w-full ah-card p-7">
  <%= link_to "← Security", onboarding_path, class: "inline-block mb-4 font-semibold text-sm text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  <span class="ah-badge ah-badge--passkey text-white">⬡ Passkeys</span>
  <h1 class="text-[28px] mt-3">Passkeys</h1>
  <p class="mt-4 font-medium text-muted">
    Passkeys let you sign in with your fingerprint, face, screen lock, or a security key —
    no password to remember. You can register more than one (e.g. a phone and a laptop).
  </p>

  <div class="mt-6">
    <% if @credentials.any? %>
      <ul class="border-[3px] border-ink rounded-[3px] overflow-hidden divide-y-[3px] divide-ink">
        <% @credentials.each do |credential| %>
          <li class="flex items-center justify-between gap-4 bg-paper px-4 py-3.5">
            <div class="min-w-0">
              <p class="font-bold text-ink truncate"><%= credential.nickname %></p>
              <p class="font-mono text-[13px] text-muted">
                Added <%= credential.created_at.to_date.to_fs(:long) %><%= " · last used #{credential.last_used_at.to_date.to_fs(:long)}" if credential.last_used_at %>
              </p>
            </div>
            <%= button_to "Remove", webauthn_credential_path(credential), method: :delete,
                  class: "ah-btn ah-btn--secondary text-[13px] py-2 px-3.5 cursor-pointer" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="font-medium text-muted border-[3px] border-dashed border-[#b8b3a8] rounded-[3px] bg-locked px-4 py-5 text-center">
        You haven't registered any passkeys yet.
      </p>
    <% end %>
  </div>

  <div class="mt-6 border-t-[3px] border-ink pt-5"
       data-controller="webauthn-registration"
       data-webauthn-registration-options-url-value="<%= options_webauthn_credentials_path %>"
       data-webauthn-registration-callback-url-value="<%= webauthn_credentials_path %>">
    <h2 class="text-xl">Add a passkey</h2>
    <p class="ah-hint mt-1">Give it a name so you can tell your devices apart.</p>

    <p data-webauthn-registration-target="error" class="ah-error mt-3 empty:hidden"></p>

    <div class="mt-4 space-y-3">
      <input type="text" data-webauthn-registration-target="nickname"
             placeholder="e.g. MacBook, iPhone, YubiKey"
             class="ah-input sm:w-80">
      <div>
        <button type="button"
                data-action="webauthn-registration#register"
                data-webauthn-registration-target="submit"
                class="ah-btn ah-btn--primary shadow-brut">
          ⬡ Add a passkey
        </button>
      </div>
    </div>
  </div>
</div>
