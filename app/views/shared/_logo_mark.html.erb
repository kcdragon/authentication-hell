<%# locals: (size: "1.5rem", tone: :default, digits: true, shadow: false, label: "AUTHHELL") %>

<%# The AUTHHELL "The Code" mark: a 2×2 grid of OTP cells reading 6 6 6 / red 0.
    Fixed brand colours (ink / white / red) per tone — never recolour with the
    accent palette. Favicons are generated from the same geometry by bin/build-favicons. %>
<%
  ink, paper, white, red, ink_cell = "#111111", "#f5f2e9", "#ffffff", "#e5342a", "#1c1c22"
  container, cell_fill, digit_fill =
    case tone
    when :reversed then [ paper, [ ink_cell, ink_cell, ink_cell, red ], [ white, white, white, white ] ]
    when :mono     then [ ink,   [ white, white, white, ink ],          [ ink, ink, ink, white ] ]
    when :all_red  then [ ink,   [ red, red, red, ink ],                [ white, white, white, white ] ]
    else                [ ink,   [ white, white, white, red ],          [ ink, ink, ink, white ] ]
    end

  b, c, g, rx = 2.5, 44.5, 6.0, 12.0
  cells  = [ [ 0, 0 ], [ 1, 0 ], [ 0, 1 ], [ 1, 1 ] ]
  glyphs = %w[6 6 6 0]
  off    = shadow ? 7 : 0
  span   = 100 + off
  cid    = "ahm#{SecureRandom.hex(3)}"
%>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 <%= span %> <%= span %>"
     style="width:<%= size %>;height:<%= size %>;display:inline-block;vertical-align:middle"
     <% if label.present? %>role="img" aria-label="<%= label %>"<% else %>aria-hidden="true"<% end %>>
  <%# Cells clip to a rect inset by the frame width so the ink border stays even
      around the rounded corners and the cells round concentrically inside it. %>
  <defs><clipPath id="<%= cid %>"><rect x="<%= b %>" y="<%= b %>" width="<%= 100 - 2 * b %>" height="<%= 100 - 2 * b %>" rx="<%= rx - b %>"/></clipPath></defs>
  <% if shadow %><rect x="<%= off %>" y="<%= off %>" width="100" height="100" rx="<%= rx %>" fill="<%= ink %>"/><% end %>
  <rect width="100" height="100" rx="<%= rx %>" fill="<%= container %>"/>
  <g clip-path="url(#<%= cid %>)">
    <% cells.each_with_index do |(col, row), i| %>
      <rect x="<%= b + col * (c + g) %>" y="<%= b + row * (c + g) %>" width="<%= c %>" height="<%= c %>" fill="<%= cell_fill[i] %>"/>
    <% end %>
  </g>
  <% if digits %>
    <% cells.each_with_index do |(col, row), i| %>
      <text x="<%= b + col * (c + g) + c / 2 %>" y="<%= b + row * (c + g) + c / 2 + 0.5 %>"
            font-family="Archivo Black" font-weight="400" font-size="23"
            text-anchor="middle" dominant-baseline="central" fill="<%= digit_fill[i] %>"><%= glyphs[i] %></text>
    <% end %>
  <% end %>
</svg>
