<div class="mx-auto max-w-md w-full ah-card p-6"
     data-controller="webauthn-registration"
     data-webauthn-registration-options-url-value="<%= options_webauthn_credentials_path %>"
     data-webauthn-registration-callback-url-value="<%= webauthn_credentials_path %>">
  <h1 class="text-[28px]">Add your passkey</h1>
  <p class="mt-4 font-medium text-muted">
    Finish creating <strong class="text-ink"><%= @user.username %></strong> by registering a passkey on this
    device. Your browser will ask you to confirm with a fingerprint, face, PIN, or security key.
  </p>

  <p data-webauthn-registration-target="error" class="ah-error mt-4 empty:hidden"></p>

  <div class="mt-6">
    <button type="button"
            data-action="webauthn-registration#register"
            data-webauthn-registration-target="submit"
            class="ah-btn ah-btn--primary shadow-brut">
      ⬡ Create passkey
    </button>
  </div>

  <p class="mt-8 font-medium text-sm text-muted">
    <%= link_to "Start over", new_registration_path, class: "text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  </p>
</div>
