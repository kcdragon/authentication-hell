<div class="mx-auto md:w-2/3 w-full"
     data-controller="webauthn-registration"
     data-webauthn-registration-options-url-value="<%= options_webauthn_credentials_path %>"
     data-webauthn-registration-callback-url-value="<%= webauthn_credentials_path %>">
  <h1 class="font-bold text-4xl">Add your passkey</h1>
  <p class="mt-4 text-gray-700">
    Finish creating <strong><%= @user.username %></strong> by registering a passkey on this
    device. Your browser will ask you to confirm with a fingerprint, face, PIN, or security key.
  </p>

  <p data-webauthn-registration-target="error" class="mt-4 text-red-500 font-medium"></p>

  <div class="mt-6">
    <button type="button"
            data-action="webauthn-registration#register"
            data-webauthn-registration-target="submit"
            class="rounded-lg px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer">
      Create passkey
    </button>
  </div>

  <div class="mt-8 text-sm text-gray-500">
    <%= link_to "Start over", new_registration_path, class: "text-gray-700 underline hover:no-underline" %>
  </div>
</div>
