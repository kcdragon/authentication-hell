<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Authentication Hell" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# The DragonRuby loader fetches its assets with bare relative paths, so a
        document base of /game/ makes them resolve against the static bundle.
        This layout intentionally omits Turbo/importmap so the base href has
        nothing to interfere with. %>
    <base href="/game/">

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%= yield :head %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
