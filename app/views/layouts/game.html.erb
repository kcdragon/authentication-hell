<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Authentication Hell" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# The DragonRuby loader fetches its assets with bare relative paths, so a
        document base of the (per-environment) bundle path makes them resolve
        against the static bundle. This layout intentionally omits Turbo/importmap
        so the base href has nothing to interfere with. %>
    <base href="<%= game_assets_path %>">

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%= yield :head %>
  </head>

  <%# DragonRuby's HTML5 loader routes canvas clicks through
      document.getElementById("toplevel").click()/focus(); its standalone build
      puts this id on <body>. Without it the loader throws "Cannot read
      properties of null (reading 'click')" on every canvas click. %>
  <body id="toplevel">
    <%= yield %>
  </body>
</html>
