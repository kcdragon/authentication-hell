<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Authentication Hell" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%# No app-wide importmap: the game canvas lives in an <iframe> (its loader
        boots there), and this page declares its own page-scoped importmap for the
        few modules the toast/nav chrome needs. No <base href> here — that belongs
        to the iframe document, which owns the game bundle's relative asset paths. %>
    <%= yield :head %>
    <%= render "shared/analytics" if Rails.env.production? %>
  </head>

  <body>
    <header class="border-b-[3px] border-ink bg-paper">
      <div class="container mx-auto px-5 py-4 flex items-center justify-between gap-4">
        <%= link_to root_path, data: { turbo: false }, class: "font-display text-xl uppercase tracking-tight" do %>
          AUTH<span class="text-error">HELL</span>
        <% end %>
        <%= render "shared/navigation", turbo: false %>
      </div>
    </header>

    <%= yield %>
  </body>
</html>
