<div class="mx-auto max-w-md w-full ah-card p-6">
  <h1 class="text-[28px]">Forgot your password?</h1>

  <%= form_with url: passwords_path, class: "mt-4 space-y-3.5" do |form| %>
    <div class="space-y-1.5">
      <%= form.label :email_address, "Email", class: "ah-label" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "player@example.com", value: params[:email_address], class: "ah-input" %>
    </div>

    <%= form.submit "Email reset instructions", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer" %>
  <% end %>
</div>
