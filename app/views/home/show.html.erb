<% content_for :title, "Authentication Hell" %>

<section class="mx-auto w-full max-w-4xl ah-card overflow-hidden">
  <div class="p-8 md:p-12" style="background-image:radial-gradient(circle at 1px 1px,#1111110f 1px,transparent 0);background-size:22px 22px">
    <span class="ah-badge ah-badge--totp text-white">
      <span class="size-2 rounded-full bg-ink animate-pulse"></span> Alpha · In development
    </span>

    <h1 class="font-display text-5xl md:text-[74px] leading-[.92] uppercase tracking-tight mt-6">
      Authentication<br>
      <span class="text-paper [-webkit-text-stroke:3px_#111]">Hell</span>
    </h1>

    <p class="font-medium text-lg text-muted max-w-[52ch] mt-6">
      A tongue-in-cheek platformer about the pain of logging in. Run, jump, and dodge —
      but the moment an enemy catches you the game freezes and makes you re-authenticate:
      passkey, two-factor code, or password. Survival means proving who you are, over and over.
    </p>

    <div class="flex flex-wrap items-center gap-3.5 mt-8">
      <% if authenticated? %>
        <%= link_to "Play now ▶", game_path, class: "ah-btn ah-btn--primary shadow-brut" %>
      <% else %>
        <%= link_to "Create account", new_registration_path, class: "ah-btn ah-btn--primary shadow-brut" %>
        <%= link_to "Sign in", new_session_path, class: "ah-btn ah-btn--secondary shadow-brut" %>
      <% end %>
    </div>
  </div>

  <%# RubyConf 2026 talk callout, fronted by the talk banner. %>
  <div class="border-t-[3px] border-ink">
    <%= image_tag "rubyconf-2026-banner.png",
          alt: "RubyConf 2026 — Welcome to Authentication Hell, a talk by Mike Dalton",
          class: "block w-full" %>
    <div class="px-6 md:px-12 py-5 border-t-[3px] border-ink bg-card">
      <p class="font-medium text-ink">
        This game is being built in the open as part of
        <span class="font-bold">“Welcome to Authentication Hell”</span>, a talk by Mike Dalton at
        <%= link_to "RubyConf 2026", "https://rubyconf.org/",
              class: "text-passkey underline underline-offset-2 decoration-2 font-bold hover:no-underline" %>.
      </p>
      <p class="font-mono text-sm text-muted mt-1.5">
        Thursday, July 16, 2026 · 11:15&nbsp;am · Red Rock Casino Resort, Las Vegas, Nevada
      </p>
    </div>
  </div>
</section>

<div class="mx-auto w-full max-w-4xl mt-4 text-center">
  <%= link_to "Acknowledgements", acknowledgements_path,
        class: "font-semibold text-sm text-muted underline underline-offset-2 hover:text-ink" %>
</div>
