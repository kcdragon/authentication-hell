<% content_for :title, "Authentication Hell" %>

<div class="mx-auto w-full max-w-3xl flex flex-col items-center text-center gap-6">
  <span class="inline-flex items-center gap-2 rounded-full bg-purple-100 border border-purple-300 px-3 py-1 text-sm font-medium text-purple-900">
    <span class="h-2 w-2 rounded-full bg-purple-500"></span>
    Alpha · In development
  </span>

  <h1 class="font-bold text-5xl text-gray-900">Authentication Hell</h1>

  <p class="text-lg text-gray-600 max-w-2xl">
    A tongue-in-cheek platformer about the pain of logging in. Run, jump, and dodge —
    but the moment an enemy catches you the game freezes and makes you re-authenticate:
    passkey, two-factor code, or password. Survival means proving who you are, over and over.
  </p>

  <div class="flex items-center gap-3 mt-2">
    <% if authenticated? %>
      <%= link_to "Play now", game_path,
            class: "rounded-md bg-blue-600 hover:bg-blue-500 text-white font-medium px-5 py-2.5" %>
    <% else %>
      <%= link_to "Create account", new_registration_path,
            class: "rounded-md bg-blue-600 hover:bg-blue-500 text-white font-medium px-5 py-2.5" %>
      <%= link_to "Sign in", new_session_path,
            class: "rounded-md bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium px-5 py-2.5" %>
    <% end %>
  </div>

  <%# RubyConf 2026 talk callout, fronted by the talk banner. %>
  <div class="w-full mt-10 rounded-lg border border-gray-200 bg-white shadow-sm overflow-hidden">
    <%= image_tag "rubyconf-2026-banner.png",
          alt: "RubyConf 2026 — Welcome to Authentication Hell, a talk by Mike Dalton",
          class: "block w-full" %>
    <div class="px-5 py-4 text-left">
      <p class="text-gray-700">
        This game is being built in the open as part of
        <span class="font-medium">“Welcome to Authentication Hell”</span>, a talk by Mike Dalton at
        <%= link_to "RubyConf 2026", "https://rubyconf.org/",
              class: "text-blue-600 hover:text-blue-500 font-medium" %>.
      </p>
      <p class="text-sm text-gray-500 mt-1">
        Thursday, July 16, 2026 · 11:15&nbsp;am · Red Rock Casino Resort, Las Vegas, Nevada
      </p>
    </div>
  </div>
</div>
