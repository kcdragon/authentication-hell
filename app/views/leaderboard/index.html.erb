<div class="mx-auto max-w-3xl w-full">
  <h1 class="font-display text-4xl uppercase tracking-tight">Leaderboard</h1>
  <p class="ah-hint mt-1"><%= leaderboard_hint %></p>

  <nav aria-label="Leaderboard tabs" class="mt-6 flex gap-2">
    <%= leaderboard_tab_link "Achievements", "achievements" %>
    <%= leaderboard_tab_link "Auths", "auths" %>
    <%= leaderboard_tab_link "Defeats", "defeats" %>
    <%= leaderboard_tab_link "Times", "times" %>
  </nav>

  <% if @tab == "times" %>
    <%= render "times", boards: @level_boards %>
  <% else %>
    <%= render @tab, users: @users, game_stats: @game_stats %>
  <% end %>
</div>
