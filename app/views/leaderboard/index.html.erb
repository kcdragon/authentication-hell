<h1 class="font-bold text-4xl">Leaderboard</h1>
<p class="mt-1 text-sm text-gray-500">The furthest, most-decorated players. Sort by level or achievements.</p>

<div class="mt-6 flex items-center gap-4 px-4 text-xs uppercase tracking-wide">
  <span class="w-8 text-gray-500">#</span>
  <span class="flex-1 text-gray-500">Player</span>
  <span class="w-40"><%= leaderboard_sort_link "Level", "level" %></span>
  <span class="w-28 text-right"><%= leaderboard_sort_link "Achievements", "achievements" %></span>
</div>

<ul class="mt-2 flex flex-col gap-3">
  <% @users.each.with_index(1) do |user, rank| %>
    <% mine = user == Current.user %>
    <% level = user.current_level %>
    <li class="flex items-center gap-4 rounded-lg border px-4 py-3
               <%= mine ? "border-amber-300 bg-amber-50" : "border-gray-200 bg-gray-50" %>">
      <span class="w-8 font-semibold <%= mine ? "text-amber-700" : "text-gray-500" %>"><%= rank %></span>
      <div class="flex flex-1 items-center gap-3 min-w-0">
        <%= avatar_badge(user) %>
        <span class="font-medium truncate <%= "text-amber-900" if mine %>"><%= user.username %></span>
      </div>
      <span class="w-40 flex items-center gap-2">
        <span class="text-xl" aria-hidden="true"><%= level.emoji %></span>
        <span class="text-sm">Level <%= level.number %>: <%= level.name %></span>
      </span>
      <span class="w-28 text-right text-sm">
        <%= user.achievements_count %> / <%= Achievement.all.size %>
      </span>
    </li>
  <% end %>
</ul>
