<div class="mx-auto max-w-md w-full ah-card p-6"
     data-controller="tabs"
     data-tabs-active-value="<%= @signup_method || "password" %>"
     data-tabs-active-class="bg-password text-ink"
     data-tabs-inactive-class="bg-card text-muted hover:bg-paper">
  <%= link_to root_path, class: "inline-block mb-5", aria: { label: "Authentication Hell — home" } do %>
    <%= render "shared/logo", layout: :horizontal %>
  <% end %>

  <h1 class="text-[28px] leading-[.95]">Create an account</h1>

  <div class="inline-flex border-[3px] border-ink rounded-[3px] overflow-hidden mt-4">
    <button type="button" data-tabs-target="tab" data-tabs-name="password" data-action="tabs#select"
            class="px-[18px] py-2.5 font-bold text-[13px] uppercase tracking-wide border-r-[3px] border-ink cursor-pointer">Password</button>
    <button type="button" data-tabs-target="tab" data-tabs-name="passkey" data-action="tabs#select"
            class="px-[18px] py-2.5 font-bold text-[13px] uppercase tracking-wide cursor-pointer">Passkey</button>
  </div>

  <% if @user.errors.any? %>
    <div class="ah-flash ah-flash--error mt-5">
      <ul class="list-disc list-inside">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-tabs-target="panel" data-tabs-name="password">
    <%= form_with model: @user, url: registration_path, class: "mt-5 space-y-3.5" do |form| %>
      <div class="space-y-1.5">
        <%= form.label :username, class: "ah-label" %>
        <%= form.text_field :username, required: true, autocomplete: "username", placeholder: "Choose a username", class: "ah-input" %>
      </div>

      <div class="space-y-1.5">
        <%= form.label :email_address, "Email", class: "ah-label" %>
        <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "Enter your email address", class: "ah-input" %>
      </div>

      <div class="space-y-1.5">
        <%= form.label :password, class: "ah-label" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Choose a password", maxlength: 72, class: "ah-input" %>
      </div>

      <div class="space-y-1.5">
        <%= form.label :password_confirmation, "Confirm password", class: "ah-label" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", maxlength: 72, class: "ah-input" %>
      </div>

      <%# Honeypot: hidden from humans, tempting to bots. A filled :nickname is dropped server-side. %>
      <div class="absolute left-[-9999px] top-[-9999px]" aria-hidden="true">
        <%= label_tag :nickname, "Nickname" %>
        <%= text_field_tag :nickname, nil, tabindex: -1, autocomplete: "off" %>
      </div>

      <%= form.submit "Create account", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer" %>
    <% end %>
  </div>

  <div data-tabs-target="panel" data-tabs-name="passkey" hidden>
    <%# turbo: false — success renders the full "add your passkey" page rather
        than redirecting, which Turbo rejects for form submissions. %>
    <%= form_with model: @user, url: passkey_registration_path, class: "mt-5 space-y-3.5", data: { turbo: false } do |form| %>
      <p class="font-medium text-muted">
        Create your account with a passkey — your fingerprint, face, screen lock, or a
        security key. No password to remember.
      </p>

      <div class="space-y-1.5">
        <%= form.label :username, class: "ah-label" %>
        <%= form.text_field :username, required: true, id: "passkey_username", autocomplete: "username", placeholder: "Choose a username", class: "ah-input" %>
      </div>

      <div class="space-y-1.5">
        <%= form.label :email_address, "Email", class: "ah-label" %>
        <%= form.email_field :email_address, required: true, id: "passkey_email_address", autocomplete: "email", placeholder: "Enter your email address", class: "ah-input" %>
      </div>

      <%= form.submit "⬡ Continue with a passkey", class: "ah-btn ah-btn--outline w-full cursor-pointer" %>
    <% end %>
  </div>

  <p class="mt-8 font-medium text-sm text-muted">
    <%= link_to "Already have an account? Sign in", new_session_path, class: "text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  </p>
</div>
