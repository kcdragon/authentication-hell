<div class="mx-auto max-w-md w-full ah-card p-6">
  <h1 class="text-[28px]">Sign in</h1>

  <%= form_with url: session_url, class: "mt-4 space-y-3.5" do |form| %>
    <div class="space-y-1.5">
      <%= form.label :email_address, "Email", class: "ah-label" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "player@example.com", value: params[:email_address], class: "ah-input" %>
    </div>

    <div class="space-y-1.5">
      <%= form.label :password, class: "ah-label" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "ah-input" %>
    </div>

    <div class="flex items-center gap-5 pt-1">
      <%= form.submit "Sign in", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer" %>
      <%= link_to "Forgot password?", new_password_path, class: "font-semibold text-sm text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
    </div>
  <% end %>

  <div class="flex items-center gap-3 my-5 font-bold text-xs uppercase tracking-widest text-muted">
    <span class="flex-1 h-[3px] bg-ink"></span>or<span class="flex-1 h-[3px] bg-ink"></span>
  </div>

  <div data-controller="webauthn-authentication"
       data-webauthn-authentication-options-url-value="<%= options_webauthn_authentication_path %>"
       data-webauthn-authentication-callback-url-value="<%= webauthn_authentication_path %>">
    <p data-webauthn-authentication-target="error" class="ah-error mb-3 empty:hidden"></p>
    <button type="button"
            data-action="webauthn-authentication#authenticate"
            class="ah-btn ah-btn--outline w-full">
      ⬡ Sign in with a passkey
    </button>
  </div>

  <p class="mt-6 font-medium text-sm text-muted">
    <%= link_to "Create an account", new_registration_path, class: "text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
    &middot;
    <%= link_to "Resend confirmation", new_email_confirmation_path, class: "text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  </p>
</div>
