<%= tag.div id: passkey_challenge_toast_id(user), class: "game-challenge-toast max-w-sm rounded-md bg-blue-100 border border-blue-300 text-blue-900 px-4 py-3 shadow-lg pointer-events-auto" do %>
  <p class="font-semibold">You bumped into the passkey enemy!</p>
  <p class="mt-1 text-sm">Passkey sign-in is coming soon. Dismiss this to keep playing for now.</p>

  <%= form_with url: games_passkey_complete_path, method: :post, authenticity_token: false, class: "mt-3" do |form| %>
    <%= form.submit "Dismiss",
          class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
  <% end %>
<% end %>
