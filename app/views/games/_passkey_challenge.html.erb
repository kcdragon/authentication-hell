<%= tag.div id: passkey_challenge_toast_id(user),
      class: "game-challenge-toast w-[346px] max-w-[90vw] border-[3px] border-ink rounded-[3px] bg-card shadow-brut-lg overflow-hidden pointer-events-auto",
      data: {
        controller: "games-passkey-challenge",
        games_passkey_challenge_options_url_value: games_passkey_options_path,
        games_passkey_challenge_callback_url_value: games_passkey_complete_path
      } do %>
  <div class="flex items-center justify-between border-b-[3px] border-ink px-4 py-2.5 bg-passkey text-white font-display text-[13px] uppercase tracking-tight">
    <span>Passkey Checkpoint</span>
    <span class="ah-badge bg-card text-ink text-[10px] py-1 shadow-none">⬡</span>
  </div>
  <div class="p-4">
    <p class="font-bold text-base">You bumped into the passkey enemy!</p>
    <p class="ah-hint mt-0.5">Re-authenticate with your passkey to keep playing.</p>

    <p class="ah-error mt-2 empty:hidden" data-games-passkey-challenge-target="error"></p>

    <% if user.webauthn_credentials.exists? %>
      <button type="button" data-action="games-passkey-challenge#verify"
              class="ah-btn ah-btn--primary w-full mt-3 cursor-pointer">
        ⬡ Verify with passkey
      </button>
    <% else %>
      <p class="mt-2 text-xs font-medium text-passkey">
        You haven't registered a passkey yet, so you can't clear this.
        Add one from the "Passkeys" settings first.
      </p>
    <% end %>
  </div>
<% end %>
