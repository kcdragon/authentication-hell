<%# locals: (user:, error: nil) %>

<%= tag.div id: totp_challenge_toast_id(user), class: "game-challenge-toast w-[346px] max-w-[90vw] border-[3px] border-ink rounded-[3px] bg-card shadow-brut-lg overflow-hidden pointer-events-auto" do %>
  <div class="flex items-center justify-between border-b-[3px] border-ink px-4 py-2.5 bg-totp text-white font-display text-[13px] uppercase tracking-tight">
    <span>Enemy Encounter</span>
    <span class="ah-badge bg-card text-ink text-[10px] py-1 shadow-none">2FA</span>
  </div>
  <div class="p-4">
    <p class="font-bold text-base">You bumped into the enemy!</p>
    <p class="ah-hint mt-0.5">Re-authenticate with your TOTP code to keep playing.</p>

    <% if local_assigns[:error].present? %>
      <p class="ah-error mt-2"><%= error %></p>
    <% end %>

    <%= form_with url: games_totp_complete_path, method: :post, authenticity_token: false, class: "mt-3 flex items-center gap-2" do |form| %>
      <%= form.text_field :code, required: true, autofocus: true,
            value: dev_totp_prefill(user),
            autocomplete: "one-time-code", inputmode: "numeric",
            placeholder: "6-digit code",
            class: "ah-input flex-1 focus:border-totp focus:shadow-[3px_3px_0_var(--color-totp)]" %>
      <%= form.submit "Verify",
            class: "ah-btn text-white cursor-pointer", style: "background: var(--color-totp)" %>
    <% end %>

    <% unless user.totp_enabled? %>
      <p class="mt-2 text-xs font-medium text-totp">
        You haven't set up two-factor authentication yet, so you can't clear this.
        Enable it from the “Two-factor authentication” menu first.
      </p>
    <% end %>
  </div>
<% end %>
