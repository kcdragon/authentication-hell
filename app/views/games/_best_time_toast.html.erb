<%# locals: (level:, ms:) %>

<div id="best_time_toast_level_<%= level.number %>"
     class="game-toast w-max max-w-[90vw] border-[3px] border-ink rounded-[3px] bg-password text-ink px-3.5 py-3 shadow-brut pointer-events-none">
  <div class="flex items-center gap-3">
    <span class="text-2xl" aria-hidden="true">⏱️</span>
    <div>
      <p class="font-display text-[11px] uppercase tracking-tight">🏁 New best time</p>
      <p class="font-display text-lg uppercase tracking-tight mt-0.5">
        <%= level.name %> — <%= leaderboard_time(ms) %>
      </p>
    </div>
  </div>
</div>
