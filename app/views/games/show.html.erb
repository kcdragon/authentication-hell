<% content_for :title, "Authentication Hell — Play" %>

<div class="w-full flex flex-col items-center gap-4 mt-8 px-5">
  <div class="w-full max-w-[1660px] flex flex-col lg:flex-row gap-4 items-start">
    <%# The game needs a same-origin <iframe> with an exactly-16:9 viewport: the
        DragonRuby engine fills its whole *document*, so a bare canvas on this
        shared page would letterbox. %>
    <div class="flex-1 min-w-0 w-full max-w-[1280px]">
      <div class="w-full bg-black border-[3px] border-ink rounded-[3px] shadow-brut overflow-hidden" style="aspect-ratio: 16 / 9;">
        <iframe
          src="<%= game_frame_path(level: params[:level]) %>"
          name="<%= game_frame_name %>"
          title="Authentication Hell"
          class="block w-full h-full border-0"
          allow="autoplay; fullscreen; gamepad"
          data-controller="game-frame"
          data-game-frame-toasts-value="<%= Game::Toasts::PERMANENT_CONTAINER %>"></iframe>
      </div>
    </div>

    <%= turbo_stream_from Current.user, :playlist %>
    <%= render "games/playlist", user: Current.user %>
  </div>

  <%= turbo_stream_from Current.user, :toasts %>
  <div class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-2">
    <div id="<%= Game::Toasts::PERMANENT_CONTAINER %>" class="contents">
      <%= render "games/certificate_toast" if Current.user.beat_game? %>
    </div>
    <div id="<%= Game::Toasts::EPHEMERAL_CONTAINER %>" class="contents"></div>
  </div>

  <%# The game_page layout omits the app-wide importmap, so declare a page-scoped
      one with absolute, digested asset URLs. %>
  <script type="importmap">
    {
      "imports": {
        "@hotwired/turbo-rails": "<%= asset_path("turbo.min.js") %>",
        "@hotwired/stimulus": "<%= asset_path("stimulus.min.js") %>",
        "@github/webauthn-json": "<%= asset_path("@github--webauthn-json.js") %>",
        "lib/webauthn_ceremony_controller": "<%= asset_path("lib/webauthn_ceremony_controller.js") %>",
        "controllers/games_passkey_challenge_controller": "<%= asset_path("controllers/games_passkey_challenge_controller.js") %>",
        "controllers/dropdown_controller": "<%= asset_path("controllers/dropdown_controller.js") %>",
        "controllers/game_frame_controller": "<%= asset_path("controllers/game_frame_controller.js") %>"
      }
    }
  </script>
  <script type="module">
    import "@hotwired/turbo-rails"
    import { Application } from "@hotwired/stimulus"
    import GamesPasskeyChallengeController from "controllers/games_passkey_challenge_controller"
    import DropdownController from "controllers/dropdown_controller"
    import GameFrameController from "controllers/game_frame_controller"

    const application = Application.start()
    application.register("games-passkey-challenge", GamesPasskeyChallengeController)
    application.register("dropdown", DropdownController)
    application.register("game-frame", GameFrameController)
  </script>
</div>
