<% content_for :title, "Authentication Hell — Play" %>

<div class="w-full flex flex-col items-center gap-4 mt-8 px-5">
  <div class="ah-flash ah-flash--notice md:hidden w-full max-w-[1280px]">
    Authentication Hell plays best on a desktop with a keyboard — the game may be
    cramped and hard to control on a small screen.
  </div>

  <div class="w-full max-w-[1660px] flex flex-col lg:flex-row gap-4 items-start" data-controller="playlist-toggle">
    <%# The game needs a same-origin <iframe> with an exactly-16:9 viewport: the
        DragonRuby engine fills its whole *document*, so a bare canvas on this
        shared page would letterbox. %>
    <div class="flex-1 min-w-0 w-full max-w-[1280px]" data-playlist-toggle-target="game">
      <div class="w-full bg-black border-[3px] border-ink rounded-[3px] shadow-brut overflow-hidden" style="aspect-ratio: 16 / 9;">
        <iframe
          src="<%= game_frame_path(level: params[:level]) %>"
          name="<%= game_frame_name %>"
          title="Authentication Hell"
          class="block w-full h-full border-0"
          allow="autoplay; fullscreen; gamepad"
          data-controller="game-frame"
          data-game-frame-toasts-value="<%= Game::Toasts::PERMANENT_CONTAINER %>"></iframe>
      </div>
    </div>

    <%= turbo_stream_from Current.user, :playlist %>
    <%= render "games/playlist", user: Current.user %>

    <%# Expand affordance shown only while the playlist is collapsed (lg+). Kept
        outside the broadcast-replaced <aside> so it always persists. %>
    <button type="button"
            data-playlist-toggle-target="rail"
            data-action="playlist-toggle#expand"
            aria-label="Show playlist" aria-expanded="false"
            class="ah-card hidden lg:flex-col items-center gap-2 self-stretch flex-shrink-0 px-2 py-3 bg-paper hover:bg-card transition cursor-pointer">
      <span aria-hidden="true" class="font-display text-ink">‹</span>
      <span class="[writing-mode:vertical-rl] rotate-180 font-display text-xs uppercase tracking-tight text-ink">Playlist</span>
    </button>
  </div>

  <%= turbo_stream_from Current.user, :toasts %>
  <div class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-2">
    <div id="<%= Game::Toasts::PERMANENT_CONTAINER %>" class="contents">
      <%= render "games/certificate_toast" if Current.user.beat_game? %>
    </div>
    <div id="<%= Game::Toasts::EPHEMERAL_CONTAINER %>" class="contents"></div>
  </div>
</div>
