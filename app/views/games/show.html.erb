<% content_for :title, "Authentication Hell — Play" %>

<div class="w-full flex flex-col items-center gap-4 mt-8 px-5">
  <div class="w-full max-w-[1280px] flex items-center justify-end">
    <%# turbo: false forces full navigations: this page sets a <base href> to the
        game bundle path and only loads Turbo for the toast stream, so let the
        browser handle the cross-layout link to the standard app pages. %>
    <%= render "shared/navigation", turbo: false %>
  </div>

  <%# Canvas (1280x720, 16:9) and the "Up Next" playlist rail side by side. The
      rail sits to the right on wide screens and stacks under the canvas below lg. %>
  <div class="w-full max-w-[1660px] flex flex-col lg:flex-row gap-4 items-start">
    <%# DragonRuby canvas plus the status/progress elements its loader looks up by
        id. The container background is paper (not black) so the engine's letterbox
        around the 16:9 frame blends into the page. %>
    <div class="flex-1 min-w-0 w-full max-w-[1280px]">
      <div class="emscripten_border bg-paper" id="borderdiv">
        <canvas
          class="emscripten block w-full"
          style="aspect-ratio: 16 / 9;"
          id="canvas"
          oncontextmenu="event.preventDefault()"
          tabindex="-1"></canvas>
      </div>

      <textarea style="display: none;" id="output" rows="8"></textarea>
      <div class="emscripten text-center text-muted text-sm mt-2" id="status"></div>
      <div class="emscripten text-center" id="progressdiv">
        <progress value="0" max="100" id="progress"></progress>
      </div>
    </div>

    <%# Playlist of "training videos" = the game's levels. Re-rendered live by
        Games::LevelsController#complete, broadcast over the :playlist stream. %>
    <%= turbo_stream_from Current.user, :playlist %>
    <%= render "games/playlist", user: Current.user %>
  </div>

  <%# Collision toasts land here. Subscribing with turbo_stream_from means the
      controller can broadcast a rendered _toast partial straight onto the page
      (Turbo appends it into #toasts) — no JS subscriber to maintain. The
      container is fixed to the bottom-right and stacks toasts as a column, so it
      floats over the page without shifting the game layout. %>
  <%= turbo_stream_from Current.user, :toasts %>
  <div id="toasts" class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-2"></div>

  <%# Resolved to <bundle path>/dragonruby-html5-loader.js via the layout's <base href>. %>
  <script src="dragonruby-html5-loader.js"></script>

  <%# Re-skin the DragonRuby loader splash to match the in-game poster. The loader
      (vendored, regenerated each build) injects div#clicktoplaydiv with the
      metadata/icon.png logo + two <p> (title, "Click or tap…"), all inline-styled.
      We can't durably edit that JS, so we override its inline styles here with
      !important and rewrite the two text lines to the poster copy once they appear.
      Colors/fonts mirror constants.rb (PAPER/INK/MUTED, Archivo Black/Space Mono). %>
  <style>
    #clicktoplaydiv { background-color: #F5F2E9 !important; border: 3px solid #141417 !important; }
    #clicktoplaydiv p { background-color: transparent !important; }
    #clicktoplaydiv p:nth-of-type(1) {
      font-family: "Archivo Black", system-ui, sans-serif !important;
      text-transform: uppercase; letter-spacing: -0.01em;
      color: #141417 !important; font-size: 28px !important;
    }
    #clicktoplaydiv p:nth-of-type(2) {
      font-family: "Space Mono", ui-monospace, monospace !important;
      color: #5B5750 !important; font-size: 18px !important;
    }
  </style>
  <script>
    (function () {
      function rebrand(div) {
        var ps = div.querySelectorAll("p");
        if (ps[0]) ps[0].textContent = "Authentication 101";
        if (ps[1]) ps[1].textContent = "click or tap to begin onboarding";
      }
      var existing = document.getElementById("clicktoplaydiv");
      if (existing) { rebrand(existing); return; }
      var obs = new MutationObserver(function (mutations, self) {
        var div = document.getElementById("clicktoplaydiv");
        if (div) { rebrand(div); self.disconnect(); }
      });
      obs.observe(document.body, { childList: true });
    })();
  </script>

  <%# This layout deliberately omits the app-wide importmap (so the bundle-path
      <base href> can't rewrite the DragonRuby loader's bare asset paths), which
      also means no Stimulus boot. So declare a page-scoped import map of the few
      modules this page needs, pinned to absolute, digested asset URLs (absolute
      so the base href leaves them alone): Turbo for the toast stream, plus
      Stimulus and the passkey collision controller (which reuses the shared
      lib/webauthn_ceremony_controller and @github/webauthn-json). Then start
      Turbo and a minimal Stimulus app with just that one controller registered —
      it auto-connects to the toast Turbo Streams appends after load. %>
  <script type="importmap">
    {
      "imports": {
        "@hotwired/turbo-rails": "<%= asset_path("turbo.min.js") %>",
        "@hotwired/stimulus": "<%= asset_path("stimulus.min.js") %>",
        "@github/webauthn-json": "<%= asset_path("@github--webauthn-json.js") %>",
        "lib/webauthn_ceremony_controller": "<%= asset_path("lib/webauthn_ceremony_controller.js") %>",
        "controllers/games_passkey_challenge_controller": "<%= asset_path("controllers/games_passkey_challenge_controller.js") %>",
        "controllers/dropdown_controller": "<%= asset_path("controllers/dropdown_controller.js") %>"
      }
    }
  </script>
  <script type="module">
    import "@hotwired/turbo-rails"
    import { Application } from "@hotwired/stimulus"
    import GamesPasskeyChallengeController from "controllers/games_passkey_challenge_controller"
    import DropdownController from "controllers/dropdown_controller"

    const application = Application.start()
    application.register("games-passkey-challenge", GamesPasskeyChallengeController)
    application.register("dropdown", DropdownController)
  </script>
</div>
