<% content_for :title, "Authentication Hell — Play" %>

<div class="w-full flex flex-col items-center gap-4 mt-8 px-5">
  <%# Canvas (1280x720, 16:9) and the "Up Next" playlist rail side by side. The
      rail sits to the right on wide screens and stacks under the canvas below lg. %>
  <div class="w-full max-w-[1660px] flex flex-col lg:flex-row gap-4 items-start">
    <%# The game runs in a same-origin <iframe> (/game/frame). DragonRuby's HTML5
        engine sizes its render to fill its *document*, so giving it a frame whose
        viewport is exactly 16:9 makes the game fill the frame with no letterbox —
        the bare canvas on a shared page can't do this (the engine would fill the
        whole document and letterbox inside it). Same-origin, so the frame's loader
        + the game's /games/* and /game/start fetches carry the session cookie as
        before; the toast/playlist/nav chrome stays here on the parent. The 16:9
        box scales with the column width via aspect-ratio. %>
    <div class="flex-1 min-w-0 w-full max-w-[1280px]">
      <div class="w-full bg-black border-[3px] border-ink rounded-[3px] shadow-brut overflow-hidden" style="aspect-ratio: 16 / 9;">
        <iframe
          src="<%= game_frame_path(level: params[:level]) %>"
          name="<%= game_frame_name %>"
          title="Authentication Hell"
          class="block w-full h-full border-0"
          allow="autoplay; fullscreen; gamepad"
          data-controller="game-frame"
          data-game-frame-toasts-value="toasts"></iframe>
      </div>
    </div>

    <%# Playlist of "training videos" = the game's levels. Re-rendered live by
        Games::LevelsController#complete, broadcast over the :playlist stream. %>
    <%= turbo_stream_from Current.user, :playlist %>
    <%= render "games/playlist", user: Current.user %>
  </div>

  <%# Collision toasts land here. Subscribing with turbo_stream_from means the
      controller can broadcast a rendered _toast partial straight onto the page
      (Turbo appends it into #toasts) — no JS subscriber to maintain. The
      container is fixed to the bottom-right and stacks toasts as a column, so it
      floats over the page without shifting the game layout. %>
  <%= turbo_stream_from Current.user, :toasts %>
  <div id="toasts" class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-2">
    <%= render "games/certificate_toast" if Current.user.beat_game? %>
  </div>

  <%# The game canvas + its loader live in the <iframe> above; this page only needs
      the chrome's JS. The game_page layout omits the app-wide importmap, so declare
      a page-scoped one (absolute, digested asset URLs): Turbo for the toast/playlist
      streams, plus Stimulus and the passkey collision, dropdown, and game-frame
      controllers. Then start Turbo and a minimal Stimulus app — the passkey
      controller auto-connects to the challenge toast Turbo appends on collision,
      and game-frame returns keyboard focus to the iframe once a toast is resolved. %>
  <script type="importmap">
    {
      "imports": {
        "@hotwired/turbo-rails": "<%= asset_path("turbo.min.js") %>",
        "@hotwired/stimulus": "<%= asset_path("stimulus.min.js") %>",
        "@github/webauthn-json": "<%= asset_path("@github--webauthn-json.js") %>",
        "lib/webauthn_ceremony_controller": "<%= asset_path("lib/webauthn_ceremony_controller.js") %>",
        "controllers/games_passkey_challenge_controller": "<%= asset_path("controllers/games_passkey_challenge_controller.js") %>",
        "controllers/dropdown_controller": "<%= asset_path("controllers/dropdown_controller.js") %>",
        "controllers/game_frame_controller": "<%= asset_path("controllers/game_frame_controller.js") %>"
      }
    }
  </script>
  <script type="module">
    import "@hotwired/turbo-rails"
    import { Application } from "@hotwired/stimulus"
    import GamesPasskeyChallengeController from "controllers/games_passkey_challenge_controller"
    import DropdownController from "controllers/dropdown_controller"
    import GameFrameController from "controllers/game_frame_controller"

    const application = Application.start()
    application.register("games-passkey-challenge", GamesPasskeyChallengeController)
    application.register("dropdown", DropdownController)
    application.register("game-frame", GameFrameController)
  </script>
</div>
