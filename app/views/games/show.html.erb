<% content_for :title, "Authentication Hell — Play" %>

<div class="w-full flex flex-col items-center gap-4 mt-8 px-5">
  <div class="w-full max-w-[1280px] flex items-center justify-end">
    <%# turbo: false forces full navigations: this page sets <base href="/game/">
        and only loads Turbo for the toast stream, so let the browser handle the
        cross-layout link to the standard app pages. %>
    <%= render "shared/navigation", turbo: false %>
  </div>

  <%# DragonRuby canvas plus the status/progress elements its loader looks up by
      id. Native game resolution is 1280x720 (16:9). %>
  <div class="w-full max-w-[1280px]">
    <div class="emscripten_border bg-black" id="borderdiv">
      <canvas
        class="emscripten block w-full"
        style="aspect-ratio: 16 / 9;"
        id="canvas"
        oncontextmenu="event.preventDefault()"
        tabindex="-1"></canvas>
    </div>

    <textarea style="display: none;" id="output" rows="8"></textarea>
    <div class="emscripten text-center text-gray-500 text-sm mt-2" id="status"></div>
    <div class="emscripten text-center" id="progressdiv">
      <progress value="0" max="100" id="progress"></progress>
    </div>
  </div>

  <%# Collision toasts land here. Subscribing with turbo_stream_from means the
      controller can broadcast a rendered _toast partial straight onto the page
      (Turbo appends it into #toasts) — no JS subscriber to maintain. The
      container is fixed to the bottom-right and stacks toasts as a column, so it
      floats over the page without shifting the game layout. %>
  <%= turbo_stream_from Current.user, :toasts %>
  <div id="toasts" class="fixed bottom-5 right-5 z-50 flex flex-col items-end gap-2"></div>

  <%# Resolved to /game/dragonruby-html5-loader.js via the layout's <base href>. %>
  <script src="dragonruby-html5-loader.js"></script>

  <%# This layout deliberately omits the app-wide importmap (so the
      <base href="/game/"> can't rewrite the DragonRuby loader's bare asset
      paths). Turbo Streams need Turbo on the page, so declare a page-scoped
      import map pointing at Turbo's absolute, digested asset URL — absolute so
      the base href leaves it alone — then import it to start Turbo. %>
  <script type="importmap">
    {
      "imports": {
        "@hotwired/turbo-rails": "<%= asset_path("turbo.min.js") %>"
      }
    }
  </script>
  <script type="module">
    import "@hotwired/turbo-rails"
  </script>
</div>
