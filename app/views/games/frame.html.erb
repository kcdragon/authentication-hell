<%# Bare DragonRuby canvas + the status/progress elements its loader looks up by
    id. Rendered inside the 16:9 <iframe> on /game so the engine fills the frame
    with no letterbox. The toast/playlist/nav chrome all live on the parent page. %>
<div class="emscripten_border" id="borderdiv">
  <canvas
    class="emscripten"
    id="canvas"
    oncontextmenu="event.preventDefault()"
    tabindex="-1"></canvas>
</div>

<textarea style="display: none;" id="output" rows="8"></textarea>
<div style="display: none;" id="status"></div>
<div style="display: none;" id="progressdiv">
  <progress value="0" max="100" id="progress"></progress>
</div>

<%# Resolved to <bundle path>/dragonruby-html5-loader.js via the layout's <base href>. %>
<script src="dragonruby-html5-loader.js"></script>

<%# Re-skin the DragonRuby loader splash to match the in-game poster. The loader
    (vendored, regenerated each build) injects div#clicktoplaydiv with the
    metadata/icon.png logo + two <p> (title, "Click or tap…"), all inline-styled.
    We can't durably edit that JS, so we override its inline styles here with
    !important and rewrite the two text lines to the poster copy once they appear.
    Colors/fonts mirror constants.rb (PAPER/INK/MUTED, Archivo Black/Space Mono);
    this frame omits the site CSS, so re-declare the two faces, pinned to absolute
    digested asset URLs so the <base href> can't rewrite them. %>
<style>
  @font-face {
    font-family: "Archivo Black"; font-style: normal; font-weight: 400; font-display: swap;
    src: url("<%= asset_path("archivo-black-400.woff2") %>") format("woff2");
  }
  @font-face {
    font-family: "Space Mono"; font-style: normal; font-weight: 400; font-display: swap;
    src: url("<%= asset_path("space-mono-400.woff2") %>") format("woff2");
  }
  #clicktoplaydiv { background-color: #F5F2E9 !important; border: 3px solid #141417 !important; }
  #clicktoplaydiv p { background-color: transparent !important; }
  #clicktoplaydiv p:nth-of-type(1) {
    font-family: "Archivo Black", system-ui, sans-serif !important;
    text-transform: uppercase; letter-spacing: -0.01em;
    color: #141417 !important; font-size: 28px !important;
  }
  #clicktoplaydiv p:nth-of-type(2) {
    font-family: "Space Mono", ui-monospace, monospace !important;
    color: #5B5750 !important; font-size: 18px !important;
  }
</style>
<script>
  (function () {
    function rebrand(div) {
      var ps = div.querySelectorAll("p");
      if (ps[0]) ps[0].textContent = "Authentication 101";
      if (ps[1]) ps[1].textContent = "click or tap to begin onboarding";
    }
    var existing = document.getElementById("clicktoplaydiv");
    if (existing) { rebrand(existing); return; }
    var obs = new MutationObserver(function (mutations, self) {
      var div = document.getElementById("clicktoplaydiv");
      if (div) { rebrand(div); self.disconnect(); }
    });
    obs.observe(document.body, { childList: true });
  })();
</script>
