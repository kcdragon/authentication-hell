<%# The DragonRuby loader looks up the canvas and status/progress elements by id. %>
<div class="emscripten_border" id="borderdiv">
  <canvas
    class="emscripten"
    id="canvas"
    oncontextmenu="event.preventDefault()"
    tabindex="-1"></canvas>
</div>

<textarea style="display: none;" id="output" rows="8"></textarea>

<div id="loading-tray">
  <div id="progressdiv">
    <progress value="0" max="100" id="progress"></progress>
  </div>
  <div id="status"></div>
</div>

<script src="dragonruby-html5-loader.js"></script>

<%# This frame has no app-wide importmap (the loader's bare asset paths must stay
    untouched), so declare a page-scoped one with absolute, digested asset URLs. %>
<script type="importmap">
  {
    "imports": {
      "@hotwired/stimulus": "<%= asset_path("stimulus.min.js") %>",
      "controllers/game_splash_controller": "<%= asset_path("controllers/game_splash_controller.js") %>"
    }
  }
</script>
<script type="module">
  import { Application } from "@hotwired/stimulus"
  import GameSplashController from "controllers/game_splash_controller"

  const application = Application.start()
  application.register("game-splash", GameSplashController)
</script>
