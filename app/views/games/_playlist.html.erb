<%# The "Up Next" playlist: the game's levels dressed as training videos in a
    video-player sidebar. Takes a `user` local (not Current.user) so it renders
    the same way from a request and from a Turbo broadcast (see
    Games::LevelsController#complete). The outer id is the broadcast target. %>
<% hlc = user.highest_level_completed
   levels = GameLevel.all
   current_number = user.current_level&.number
   watched_count = levels.count { |l| hlc && l.number <= hlc }
   # Cosmetic m:ss per level (the in-game scrubber fakes a 3:20 runtime).
   durations = { 0 => "0:45", 1 => "3:20" }
   # Decorative locked entries so the rail reads as a fuller course playlist.
   coming_soon = [ "OAuth & SSO", "Session Hygiene", "Spotting Phishing", "Recovery Codes 201" ]
   total = levels.size + coming_soon.size %>

<aside id="<%= playlist_dom_id %>" class="ah-card w-full lg:w-[346px] lg:flex-shrink-0 overflow-hidden">
  <div class="border-b-[3px] border-ink px-4 py-3 bg-paper">
    <p class="font-display text-sm uppercase tracking-tight">Authentication 101</p>
    <p class="font-mono text-xs text-muted mt-1"><%= watched_count %> watched · <%= total %> videos</p>
  </div>

  <% levels.each do |level|
       watched = hlc && level.number <= hlc
       current = !watched && level.number == current_number %>
    <div class="flex items-center gap-3 px-3 py-3 border-b-[3px] border-ink last:border-b-0 <%= "bg-passkey/10" if current %> <%= "opacity-80" if watched %>">
      <div class="relative w-24 aspect-video flex-shrink-0 grid place-items-center border-[3px] border-ink rounded-[2px] bg-paper">
        <span class="text-2xl" aria-hidden="true"><%= level.emoji %></span>
        <% if current %>
          <span class="absolute inset-0 grid place-items-center">
            <span class="grid place-items-center w-7 h-7 rounded-full bg-passkey text-white border-2 border-ink text-[11px] leading-none pl-0.5">▶</span>
          </span>
        <% end %>
        <span class="absolute bottom-0.5 right-0.5 font-mono text-[10px] bg-ink text-white px-1 rounded-[2px]"><%= durations[level.number] || "3:20" %></span>
      </div>

      <div class="min-w-0">
        <p class="font-display text-xs uppercase tracking-tight truncate">Lv <%= level.number %> · <%= level.name %></p>
        <% if watched %>
          <p class="font-mono text-[11px] font-bold text-success mt-1">✓ Watched</p>
        <% elsif current %>
          <span class="inline-block font-display text-[10px] uppercase tracking-tight bg-passkey text-white border-2 border-ink rounded-[2px] px-1.5 py-0.5 mt-1">▶ Now playing</span>
        <% else %>
          <p class="font-mono text-[11px] text-muted mt-1">Up next</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <% coming_soon.each do |title| %>
    <div class="flex items-center gap-3 px-3 py-3 border-b-[3px] border-dashed border-locked-ink last:border-b-0 bg-locked">
      <div class="w-24 aspect-video flex-shrink-0 grid place-items-center border-[3px] border-dashed border-locked-ink rounded-[2px] bg-locked">
        <span class="text-xl opacity-60" aria-hidden="true">🔒</span>
      </div>
      <div class="min-w-0">
        <p class="font-display text-xs uppercase tracking-tight text-locked-ink truncate"><%= title %></p>
        <p class="font-mono text-[11px] text-locked-ink mt-1">Coming soon</p>
      </div>
    </div>
  <% end %>
</aside>
