<%= tag.div id: password_challenge_toast_id(user), class: "game-challenge-toast w-[346px] max-w-[90vw] border-[3px] border-ink rounded-[3px] bg-card shadow-brut-lg overflow-hidden pointer-events-auto" do %>
  <div class="flex items-center justify-between border-b-[3px] border-ink px-4 py-2.5 bg-password text-ink font-display text-[13px] uppercase tracking-tight">
    <span>Password Enemy</span>
    <span class="ah-badge bg-card text-ink text-[10px] py-1 shadow-none">Auth</span>
  </div>
  <div class="p-4">
    <p class="font-bold text-base">You bumped into the password enemy!</p>
    <p class="ah-hint mt-0.5">Re-authenticate with your password to keep playing.</p>

    <% if local_assigns[:error].present? %>
      <p class="ah-error mt-2"><%= error %></p>
    <% end %>

    <%= form_with url: games_password_complete_path, method: :post, authenticity_token: false, class: "mt-3 flex items-center gap-2" do |form| %>
      <%= form.password_field :password, required: true, autofocus: true,
            value: dev_password_prefill,
            autocomplete: "current-password",
            placeholder: "Your password",
            class: "ah-input flex-1 focus:border-password focus:shadow-[3px_3px_0_var(--color-password)]" %>
      <%= form.submit "Verify",
            class: "ah-btn bg-password text-ink cursor-pointer" %>
    <% end %>

    <% if user.passwordless? %>
      <p class="mt-2 text-xs font-medium text-muted">
        You haven't set up a password yet, so you can't clear this.
        Add one from the "Password" settings first.
      </p>
    <% end %>
  </div>
<% end %>
