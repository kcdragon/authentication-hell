<%= tag.div id: password_challenge_toast_id(user), class: "game-challenge-toast max-w-sm rounded-md bg-amber-100 border border-amber-300 text-amber-900 px-4 py-3 shadow-lg pointer-events-auto" do %>
  <p class="font-semibold">You bumped into the password enemy!</p>
  <p class="mt-1 text-sm">Re-authenticate with your password to keep playing.</p>

  <% if local_assigns[:error].present? %>
    <p class="mt-2 text-sm font-medium text-red-700"><%= error %></p>
  <% end %>

  <%= form_with url: games_password_complete_path, method: :post, authenticity_token: false, class: "mt-3 flex items-center gap-2" do |form| %>
    <%= form.password_field :password, required: true, autofocus: true,
          value: dev_password_prefill,
          autocomplete: "current-password",
          placeholder: "Your password",
          class: "block shadow-sm rounded-md border border-amber-300 focus:outline-solid focus:outline-amber-600 px-3 py-2 w-40" %>
    <%= form.submit "Verify",
          class: "rounded-md px-3.5 py-2 bg-amber-600 hover:bg-amber-500 text-white font-medium cursor-pointer" %>
  <% end %>

  <% if user.passwordless? %>
    <p class="mt-2 text-xs text-amber-800">
      You haven't set up a password yet, so you can't clear this.
      Add one from the "Password" settings first.
    </p>
  <% end %>
<% end %>
