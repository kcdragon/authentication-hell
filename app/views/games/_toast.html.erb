<%# One collision toast, appended into the #toasts container via Turbo Streams.
    The container (in show.html.erb) is the fixed, bottom-right flex column that
    stacks these; each toast just needs a unique DOM id and its styling. The
    fade-in + auto-dismiss is pure CSS (toast-in keyframes in game.css) — no JS
    controller. `toast` is a hash with :id and :message. %>
<div id="toast_<%= toast.fetch(:id) %>"
     class="game-toast max-w-sm rounded-md bg-purple-100 border border-purple-300 text-purple-900 px-4 py-3 font-medium shadow-lg pointer-events-none">
  <%= toast.fetch(:message) %>
</div>
