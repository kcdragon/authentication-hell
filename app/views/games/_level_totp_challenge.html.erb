<%# locals: (user:, challenge:, error: nil) %>

<% toast_animation = challenge&.registered? ? "game-challenge-toast-linked" : "game-challenge-toast" %>
<%= tag.div id: level_totp_challenge_toast_id(user), class: "#{toast_animation} w-[346px] max-w-[90vw] border-[3px] border-ink rounded-[3px] bg-card shadow-brut-lg overflow-hidden pointer-events-auto", data: { controller: "collapsible" } do %>
  <div class="flex items-center justify-between border-b-[3px] border-ink px-4 py-2.5 bg-totp text-white font-display text-[13px] uppercase tracking-tight">
    <div class="flex items-center gap-2.5">
      <button type="button" data-action="collapsible#toggle" data-collapsible-target="toggle"
              aria-label="Collapse" aria-expanded="true"
              class="ah-badge bg-card text-ink text-[13px] leading-none py-0.5 px-2 shadow-none cursor-pointer">−</button>
      <span>Temporary 2FA</span>
    </div>
    <span class="ah-badge bg-card text-ink text-[10px] py-1 shadow-none">TOTP</span>
  </div>
  <div class="p-4" data-collapsible-target="body">
    <% if challenge&.registered? %>
      <p class="font-bold text-base">Authenticator linked ✓</p>
      <p class="ah-hint mt-0.5">
        Read your authenticator and collect the six digits of each code from the
        keypad platforms. Enter three codes in a row — from consecutive 30-second
        windows — to finish the level.
      </p>
    <% else %>
      <p class="font-bold text-base">Link a temporary authenticator</p>
      <p class="ah-hint mt-0.5">Scan this QR with your authenticator app, then enter the current code to link it.</p>

      <div class="mt-3 flex flex-col items-center gap-1.5">
        <%= totp_qr_code(challenge.provisioning_uri) %>
        <code class="ah-hint text-[11px] break-all" data-secret="<%= challenge.secret %>"><%= challenge.secret %></code>
      </div>

      <% if local_assigns[:error].present? %>
        <p class="ah-error mt-2"><%= error %></p>
      <% end %>

      <%= form_with url: games_level_totp_register_path, method: :post, authenticity_token: false, class: "mt-3 flex items-center gap-2" do |form| %>
        <%= form.text_field :code, required: true, autofocus: true,
              value: (challenge.totp.now if dev_prefills_enabled?),
              autocomplete: "one-time-code", inputmode: "numeric",
              placeholder: "6-digit code",
              class: "ah-input flex-1 focus:border-totp focus:shadow-[3px_3px_0_var(--color-totp)]" %>
        <%= form.submit "Link",
              class: "ah-btn text-white cursor-pointer", style: "background: var(--color-totp)" %>
      <% end %>
    <% end %>
  </div>
<% end %>
