<% user = Current.user
   password_done = user.password_digest.present?
   passkey_done  = user.webauthn_credentials.exists?
   totp_done     = user.totp_enabled?
   done_count    = [ password_done, passkey_done, totp_done ].count(true) %>

<div class="mx-auto max-w-2xl w-full">
  <span class="ah-badge ah-badge--password text-ink"><%= done_count %>/3 set up</span>
  <h1 class="text-[32px] leading-[.95] mt-3">Security</h1>
  <p class="mt-4 font-medium text-muted">
    <% if done_count == 3 %>
      Manage the ways you sign in to Authentication Hell — your password, passkey, and authenticator app.
    <% else %>
      This is Authentication Hell — so naturally you'll set up every way in. Add a password,
      a passkey, and an authenticator app. You can do them in any order.
    <% end %>
  </p>

  <div class="mt-7 space-y-5">
    <%# 1 · Password %>
    <div class="ah-card p-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="ah-badge ah-badge--password text-ink">Password</span>
          <h2 class="text-xl">Set a password</h2>
        </div>
        <% if password_done %>
          <div class="flex items-center gap-3">
            <span class="ah-badge ah-badge--success">✓ Done</span>
            <%= link_to "Manage", password_change_path, class: "ah-btn ah-btn--ghost" %>
          </div>
        <% end %>
      </div>

      <% unless password_done %>
        <p class="ah-hint mt-3">You signed up with a passkey — add a password as a backup way in.</p>

        <%= form_with model: user, url: onboarding_password_path, method: :post, class: "mt-4 space-y-3.5" do |form| %>
          <div class="space-y-1.5">
            <%= form.label :password, "New password", class: "ah-label" %>
            <%= form.password_field :password, required: true, autocomplete: "new-password",
                  placeholder: "Choose a password", maxlength: 72,
                  class: "ah-input sm:w-80 #{'ah-input--error' if user.errors[:password].any?}" %>
          </div>
          <div class="space-y-1.5">
            <%= form.label :password_confirmation, "Confirm password", class: "ah-label" %>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
                  placeholder: "Confirm your password", maxlength: 72, class: "ah-input sm:w-80" %>
          </div>
          <%= form.submit "Set password", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer",
                style: "background: var(--color-password); color: var(--color-ink)" %>
        <% end %>
      <% end %>
    </div>

    <%# 2 · Passkey — reuses the webauthn-registration Stimulus controller %>
    <div class="ah-card p-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="ah-badge ah-badge--passkey text-white">⬡ Passkey</span>
          <h2 class="text-xl">Register a passkey</h2>
        </div>
        <% if passkey_done %>
          <div class="flex items-center gap-3">
            <span class="ah-badge ah-badge--success">✓ Done</span>
            <%= link_to "Manage", webauthn_settings_path, class: "ah-btn ah-btn--ghost" %>
          </div>
        <% end %>
      </div>

      <% unless passkey_done %>
        <div class="mt-3"
             data-controller="webauthn-registration"
             data-webauthn-registration-options-url-value="<%= options_webauthn_credentials_path %>"
             data-webauthn-registration-callback-url-value="<%= webauthn_credentials_path %>">
          <p class="ah-hint">Sign in with your fingerprint, face, screen lock, or a security key — no password to type.</p>
          <p data-webauthn-registration-target="error" class="ah-error mt-3 empty:hidden"></p>

          <div class="mt-4 space-y-3">
            <input type="text" data-webauthn-registration-target="nickname"
                   placeholder="e.g. MacBook, iPhone, YubiKey" class="ah-input sm:w-80">
            <div>
              <button type="button" data-action="webauthn-registration#register"
                      data-webauthn-registration-target="submit"
                      class="ah-btn ah-btn--primary shadow-brut">⬡ Add a passkey</button>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# 3 · Authenticator (TOTP) — links out to the existing enrollment flow %>
    <div class="ah-card p-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="ah-badge ah-badge--totp text-white">2FA</span>
          <h2 class="text-xl">Set up an authenticator app</h2>
        </div>
        <% if totp_done %>
          <div class="flex items-center gap-3">
            <span class="ah-badge ah-badge--success">✓ Done</span>
            <%= link_to "Manage", totp_settings_path, class: "ah-btn ah-btn--ghost" %>
          </div>
        <% else %>
          <%= link_to "Set up", new_totp_enrollment_path,
                class: "ah-btn ah-btn--primary shadow-brut", style: "background: var(--color-totp)" %>
        <% end %>
      </div>
      <% unless totp_done %>
        <p class="ah-hint mt-3">Scan a QR code with an app like Google Authenticator or 1Password for time-based codes.</p>
      <% end %>
    </div>
  </div>

  <div class="mt-7">
    <%= link_to "▶ Back to game", game_path, class: "ah-btn ah-btn--ghost" %>
  </div>
</div>
