<div class="mx-auto max-w-3xl w-full ah-card p-7">
  <h1 class="text-[30px]">Profile</h1>

  <div class="ah-card ah-card--flush border-[3px] bg-paper p-5 shadow-brut-sm mt-5">
    <div class="flex items-center gap-4">
      <%= avatar_badge(Current.user, size_classes: "h-16 w-16") %>
      <div>
        <h2 class="text-xl">Avatar</h2>
        <p class="ah-hint mt-1">PNG, JPEG, GIF, or WebP, up to 5 MB.</p>
      </div>
    </div>

    <%= form_with model: Current.user, url: user_path, method: :patch, class: "mt-4 flex flex-wrap items-center gap-3" do |form| %>
      <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/gif,image/webp",
            class: "block text-sm font-medium text-ink cursor-pointer
                    file:mr-3 file:border-[3px] file:border-ink file:rounded-[3px] file:px-3.5 file:py-2
                    file:bg-card file:text-ink file:font-bold file:text-sm file:cursor-pointer file:shadow-[3px_3px_0_var(--color-ink)]" %>
      <%= form.submit "Save avatar", class: "ah-btn ah-btn--primary text-[13px] cursor-pointer" %>
    <% end %>

    <% if Current.user.avatar.attached? %>
      <div class="mt-5 border-t border-faint pt-4">
        <h3 class="font-display text-sm uppercase tracking-tight">Remove avatar</h3>
        <p class="ah-hint mt-1">Revert to the initial-letter badge.</p>
        <%= button_to "Remove avatar", avatar_path, method: :delete, class: "ah-btn ah-btn--destructive text-[13px] mt-3 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%= render "users/progress" %>

  <%= render "users/achievements" %>
</div>
