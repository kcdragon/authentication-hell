<% content_for :title, "Acknowledgements" %>

<div class="mx-auto w-full max-w-3xl ah-card p-7">
  <h1 class="text-[30px]">Acknowledgements</h1>

  <p class="mt-4 font-medium text-muted">
    Authentication Hell stands on third-party artwork and tools. Thank you to the creators and communities below.
  </p>

  <section class="mt-6 border-t-[3px] border-ink pt-5">
    <h2 class="text-xl">Icons</h2>
    <ul class="mt-3 list-disc pl-6 font-medium text-ink marker:text-password">
      <li>
        <a href="https://www.flaticon.com/free-icons/passkey" title="passkey icons"
           class="text-passkey underline underline-offset-2 decoration-2 hover:no-underline">Passkey icons created by Yudhi Restu — Flaticon</a>
      </li>
      <li>
        <a href="https://www.flaticon.com/free-icons/otp" title="otp icons"
           class="text-totp underline underline-offset-2 decoration-2 hover:no-underline">Otp icons created by Uniconlabs — Flaticon</a>
      </li>
      <li>
        <a href="https://www.flaticon.com/free-icons/password" title="password icons"
           class="text-password underline underline-offset-2 decoration-2 hover:no-underline">Password icons created by Smashicons — Flaticon</a>
      </li>
      <li>
        <a href="https://www.flaticon.com/free-icons/certificate" title="certificate icons"
           class="text-passkey underline underline-offset-2 decoration-2 hover:no-underline">Certificate icons created by Freepik — Flaticon</a>
      </li>
    </ul>
  </section>

  <section class="mt-6 border-t-[3px] border-ink pt-5">
    <h2 class="text-xl">Game engine</h2>
    <ul class="mt-3 list-disc pl-6 font-medium text-ink marker:text-error">
      <li>
        <a href="https://dragonruby.org" title="DragonRuby GTK"
           class="text-error underline underline-offset-2 decoration-2 hover:no-underline">DragonRuby GTK — the engine powering the game</a>
      </li>
      <li>
        <a href="https://discord.dragonruby.org" title="DragonRuby Discord"
           class="text-error underline underline-offset-2 decoration-2 hover:no-underline">DragonRuby Discord — the community behind it</a>
      </li>
    </ul>
  </section>
</div>
