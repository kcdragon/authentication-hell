<% content_for :head do %>
  <%# Keep these one-time codes out of Turbo's back/forward page snapshot cache. %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="mx-auto max-w-md w-full">
  <h1 class="font-display text-4xl uppercase tracking-tight">Your recovery codes</h1>

  <div class="mt-6">
    <%= render "totp/recovery_codes_list", recovery_codes: @recovery_codes %>
  </div>

  <div class="mt-6">
    <%= link_to "Done", Current.user.onboarding_complete? ? totp_settings_path : onboarding_path, class: "ah-btn ah-btn--primary shadow-brut" %>
  </div>
</div>
