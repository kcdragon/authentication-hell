<div class="mx-auto max-w-2xl w-full ah-card p-7">
  <span class="ah-badge ah-badge--totp text-white">2FA Setup</span>
  <h1 class="text-[28px] mt-3">Set up two-factor authentication</h1>

  <ol class="mt-5 space-y-2 font-medium text-ink list-decimal list-inside marker:font-display marker:text-totp">
    <li>Scan the QR code below with your authenticator app.</li>
    <li>Enter the 6-digit code it shows to confirm.</li>
  </ol>

  <div class="mt-5 inline-block border-[3px] border-ink rounded-[3px] bg-card p-3 shadow-brut-sm">
    <%= totp_qr_code(@provisioning_uri) %>
  </div>

  <div class="mt-4">
    <p class="font-medium text-sm text-muted">Can't scan? Enter this secret manually:</p>
    <code class="inline-block mt-2 font-mono font-bold text-sm border-2 border-ink rounded-[3px] bg-paper px-2.5 py-1.5 tracking-wider whitespace-nowrap"><%= @secret %></code>
  </div>

  <%# turbo: false — success renders the one-time recovery codes as a full page,
      which Turbo rejects, and a plain navigation keeps them out of Turbo's cache. %>
  <%= form_with url: totp_enrollment_path, method: :post, class: "mt-5 space-y-3.5", data: { turbo: false } do |form| %>
    <div class="space-y-1.5">
      <%= form.label :code, "Verification code", class: "ah-label" %>
      <%= form.text_field :code, required: true, autofocus: true, autocomplete: "off", inputmode: "numeric", placeholder: "Enter the 6-digit code", class: "ah-input sm:w-80 focus:border-totp focus:shadow-[3px_3px_0_var(--color-totp)]" %>
    </div>

    <div class="flex items-center gap-5 pt-1">
      <%= form.submit "Confirm and enable", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer", style: "background: var(--color-totp)" %>
      <%= link_to "Cancel", Current.user.onboarding_complete? ? totp_settings_path : onboarding_path, class: "font-semibold text-sm text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
    </div>
  <% end %>
</div>
