<div class="rounded-lg border border-amber-300 bg-amber-50 p-5" data-controller="recovery-codes" data-recovery-codes-codes-value="<%= recovery_codes.to_json %>">
  <p class="font-medium text-amber-900">Save these recovery codes now.</p>
  <p class="mt-1 text-sm text-amber-800">
    Each code can be used once to sign in if you lose access to your authenticator app.
    They won't be shown again.
  </p>
  <ul class="mt-4 grid grid-cols-2 gap-2 font-mono text-sm">
    <% recovery_codes.each do |code| %>
      <li class="bg-white rounded border border-amber-200 px-3 py-1.5"><%= code %></li>
    <% end %>
  </ul>
  <div class="mt-4 flex items-center gap-3">
    <button type="button" data-action="recovery-codes#copy" class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-sm font-medium text-amber-900 hover:bg-amber-100">Copy all</button>
    <button type="button" data-action="recovery-codes#download" class="rounded-lg border border-amber-300 bg-white px-3 py-1.5 text-sm font-medium text-amber-900 hover:bg-amber-100">Download</button>
    <span data-recovery-codes-target="status" aria-live="polite" class="text-sm font-medium text-amber-800"></span>
  </div>
</div>
