<%# locals: (recovery_codes:) %>

<div class="border-[3px] border-ink rounded-[3px] bg-password shadow-brut overflow-hidden"
     data-controller="recovery-codes" data-recovery-codes-codes-value="<%= recovery_codes.to_json %>">
  <div class="px-[18px] py-3.5 border-b-[3px] border-ink font-display text-[15px] uppercase tracking-tight">
    ⚠ Save your recovery codes
  </div>
  <div class="bg-card p-[18px]">
    <p class="font-semibold text-[13.5px] mb-3.5">
      Each code can be used once to sign in if you lose access to your authenticator app.
      Store them somewhere safe — they won't be shown again.
    </p>
    <ul class="grid grid-cols-2 gap-2 font-mono font-bold text-sm tracking-wider">
      <% recovery_codes.each do |code| %>
        <li class="bg-paper border-2 border-ink rounded-[3px] px-2.5 py-2"><%= code %></li>
      <% end %>
    </ul>
    <div class="flex items-center gap-2.5 mt-4">
      <button type="button" data-action="recovery-codes#copy" class="ah-btn ah-btn--secondary text-sm cursor-pointer">Copy all</button>
      <button type="button" data-action="recovery-codes#download" class="ah-btn ah-btn--ghost text-sm cursor-pointer">Download</button>
      <span data-recovery-codes-target="status" aria-live="polite" class="font-bold text-sm text-muted"></span>
    </div>
  </div>
</div>
