<div class="mx-auto max-w-md w-full ah-card p-6">
  <h1 class="text-[28px]">Two-step verification</h1>

  <% if @pending_user.totp_enabled? %>
    <p class="mt-4 font-medium text-muted">Enter the 6-digit code from your authenticator app.</p>

    <%= form_with url: totp_challenge_path, method: :post, class: "mt-4 space-y-3.5" do |form| %>
      <div class="space-y-1.5">
        <%= form.label :code, "Code", class: "ah-label" %>
        <%= form.text_field :code, required: true, autofocus: true, value: dev_totp_prefill(@pending_user), autocomplete: "one-time-code", inputmode: "text", placeholder: "6-digit code or recovery code", class: "ah-input focus:border-totp focus:shadow-[3px_3px_0_var(--color-totp)]" %>
      </div>

      <%= form.submit "Verify", class: "ah-btn ah-btn--primary shadow-brut cursor-pointer", style: "background: var(--color-totp)" %>
      <p class="ah-hint">Lost your device? Enter one of your recovery codes instead.</p>
    <% end %>
  <% else %>
    <p class="mt-4 font-medium text-muted">Confirm it's you with one of your passkeys.</p>
  <% end %>

  <% if @pending_user.webauthn_credentials.exists? %>
    <div class="mt-5 <%= "border-t-[3px] border-ink pt-5" if @pending_user.totp_enabled? %>"
         data-controller="webauthn-authentication"
         data-webauthn-authentication-options-url-value="<%= options_webauthn_challenge_path %>"
         data-webauthn-authentication-callback-url-value="<%= webauthn_challenge_path %>">
      <p data-webauthn-authentication-target="error" class="ah-error mb-3 empty:hidden"></p>
      <button type="button"
              data-action="webauthn-authentication#authenticate"
              class="ah-btn ah-btn--outline w-full">
        ⬡ <%= @pending_user.totp_enabled? ? "Use a passkey instead" : "Continue with a passkey" %>
      </button>
    </div>
  <% end %>

  <p class="mt-8 font-medium text-sm text-muted">
    <%= link_to "Cancel and sign in again", new_session_path, class: "text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  </p>
</div>
