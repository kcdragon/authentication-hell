<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Two-factor authentication</h1>

  <% if Current.user.totp_enabled? %>
    <p class="mt-4 inline-flex items-center gap-2 rounded-full bg-green-100 text-green-800 px-3 py-1 text-sm font-medium">
      Enabled
    </p>
    <p class="mt-4 text-gray-700">
      Your account is protected by an authenticator app.
      You have <strong><%= Current.user.recovery_codes_remaining %></strong> unused recovery
      <%= "code".pluralize(Current.user.recovery_codes_remaining) %> remaining.
    </p>

    <div class="mt-8 border-t border-gray-200 pt-6 flex flex-col md:flex-row gap-8">
      <div class="flex-1">
        <h2 class="font-bold text-xl">Regenerate recovery codes</h2>
        <p class="mt-1 text-sm text-gray-500">Generates a new set and invalidates your old codes.</p>
        <%# turbo: false — on success this renders a full page of new one-time codes
            rather than redirecting, which Turbo rejects (and would otherwise cache). %>
        <%= form_with url: totp_recovery_codes_path, method: :post, class: "contents", data: { turbo: false } do |form| %>
          <div class="my-4">
            <%= form.text_field :code, autocomplete: "off", inputmode: "text", placeholder: "Current 6-digit or recovery code", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 w-full" %>
          </div>
          <%= form.submit "Regenerate codes", class: "rounded-lg px-3.5 py-2.5 bg-gray-800 hover:bg-gray-700 text-white inline-block font-medium cursor-pointer" %>
        <% end %>
      </div>

      <div class="flex-1">
        <h2 class="font-bold text-xl">Disable two-factor authentication</h2>
        <p class="mt-1 text-sm text-gray-500">Confirm with a current code or your password.</p>
        <%= form_with url: totp_settings_path, method: :delete, class: "contents" do |form| %>
          <div class="my-4">
            <%= form.text_field :code, autocomplete: "off", inputmode: "text", placeholder: "Current 6-digit or recovery code", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 w-full" %>
          </div>
          <div class="my-4">
            <%= form.password_field :password, autocomplete: "current-password", placeholder: "…or your account password", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 w-full" %>
          </div>
          <%= form.submit "Disable", class: "rounded-lg px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white inline-block font-medium cursor-pointer" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <p class="mt-4 inline-flex items-center gap-2 rounded-full bg-gray-100 text-gray-700 px-3 py-1 text-sm font-medium">
      Not enabled
    </p>
    <p class="mt-4 text-gray-700">
      Add a second step to sign-in using an authenticator app such as Google Authenticator,
      1Password, or Authy.
    </p>
    <div class="mt-6">
      <%= link_to "Set up two-factor authentication", new_totp_enrollment_path, class: "rounded-lg px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium" %>
    </div>
  <% end %>
</div>
