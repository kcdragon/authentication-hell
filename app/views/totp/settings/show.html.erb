<div class="mx-auto max-w-2xl w-full ah-card p-7">
  <%= link_to "← Security", onboarding_path, class: "inline-block mb-4 font-semibold text-sm text-ink underline underline-offset-[3px] decoration-2 hover:no-underline" %>
  <h1 class="text-[28px]">Two-factor authentication</h1>

  <% if Current.user.totp_enabled? %>
    <span class="ah-badge ah-badge--success mt-4">✓ Enabled</span>
    <p class="mt-4 font-medium text-ink">
      Your account is protected by an authenticator app.
      You have <strong><%= Current.user.recovery_codes_remaining %></strong> unused recovery
      <%= "code".pluralize(Current.user.recovery_codes_remaining) %> remaining.
    </p>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="border-[3px] border-ink rounded-[3px] bg-paper p-5 shadow-brut-sm">
        <h2 class="font-display text-base uppercase tracking-tight">Regenerate recovery codes</h2>
        <p class="ah-hint mt-1">Generates a new set and invalidates your old codes.</p>
        <%# turbo: false — on success this renders a full page of new one-time codes
            rather than redirecting, which Turbo rejects (and would otherwise cache). %>
        <%= form_with url: totp_recovery_codes_path, method: :post, class: "mt-4 space-y-3", data: { turbo: false } do |form| %>
          <%= form.text_field :code, autocomplete: "off", inputmode: "text", placeholder: "Current 6-digit or recovery code", class: "ah-input" %>
          <%= form.submit "Regenerate codes", class: "ah-btn ah-btn--secondary cursor-pointer" %>
        <% end %>
      </div>

      <div class="border-[3px] border-ink rounded-[3px] bg-paper p-5 shadow-brut-sm">
        <h2 class="font-display text-base uppercase tracking-tight">Disable two-factor</h2>
        <p class="ah-hint mt-1">Confirm with a current code or your password.</p>
        <%= form_with url: totp_settings_path, method: :delete, class: "mt-4 space-y-3" do |form| %>
          <%= form.text_field :code, autocomplete: "off", inputmode: "text", placeholder: "Current 6-digit or recovery code", class: "ah-input" %>
          <%= form.password_field :password, autocomplete: "current-password", placeholder: "…or your account password", class: "ah-input" %>
          <%= form.submit "Disable", class: "ah-btn ah-btn--destructive cursor-pointer" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <span class="ah-badge mt-4 bg-locked text-locked-ink">Not enabled</span>
    <p class="mt-4 font-medium text-ink">
      Add a second step to sign-in using an authenticator app such as Google Authenticator,
      1Password, or Authy.
    </p>
    <div class="mt-6">
      <%= link_to "Set up two-factor authentication", new_totp_enrollment_path, class: "ah-btn ah-btn--primary shadow-brut", style: "background: var(--color-totp)" %>
    </div>
  <% end %>
</div>
