#!/usr/bin/env ruby
require "fileutils"
require "digest"

APP_ROOT  = File.expand_path("..", __dir__)
GAME_DIR  = File.join(APP_ROOT, "game")
ZIP       = File.join(GAME_DIR, "builds", "authentication-hell-html5.zip")
ORIGIN_FILE = File.join(GAME_DIR, "mygame", "app", "server_config.txt")

# Output to a per-environment bundle dir so a dev build (baked for localhost) and
# a production build (baked for the live domain) never overwrite each other.
# Rails serves public/<env>_game_assets/ — see GamesController#game_assets_path.
RAILS_ENV = ENV.fetch("RAILS_ENV", "development")
PUBLIC    = File.join(APP_ROOT, "public", "#{RAILS_ENV}_game_assets")

def system!(*args) = system(*args, exception: true)

# The game runs as WASM in the browser and can't read env vars at runtime, so
# bake the Rails server origin (scheme + host[:port]) into the bundle here. Dev
# targets the local server (CONDUCTOR_PORT under Conductor, else 3000); any other
# environment must pass GAME_SERVER_ORIGIN so we never ship a localhost build.
# main.rb reads this file.
origin =
  if RAILS_ENV == "development"
    ENV.fetch("GAME_SERVER_ORIGIN", "http://localhost:#{ENV.fetch("CONDUCTOR_PORT", "3000")}")
  else
    ENV.fetch("GAME_SERVER_ORIGIN") { abort "Set GAME_SERVER_ORIGIN for a #{RAILS_ENV} build (e.g. https://authenticationhell.com)" }
  end

if !File.exist?(ORIGIN_FILE) || File.read(ORIGIN_FILE).strip != origin
  puts "== Baking server origin #{origin} into the bundle =="
  File.write(ORIGIN_FILE, origin)
end

FileUtils.chdir GAME_DIR do
  # The downloaded engine binaries carry com.apple.quarantine, which makes macOS
  # Gatekeeper prompt on every shell-launched build. Strip it (idempotent; the
  # attribute returns after a DragonRuby re-download/upgrade, so re-strip here).
  system "xattr", "-d", "com.apple.quarantine", "dragonruby-publish", err: File::NULL

  puts "== Building DragonRuby HTML5 bundle =="
  system! "./dragonruby-publish --only-package --platforms=html5 mygame"
end

abort "Build zip not found at #{ZIP}" unless File.exist?(ZIP)

# Unzip into a content-digested subdir so each build is served under a fresh,
# immutable URL. The loader fetches its sibling files (manifest.json, gamedata/,
# dragonruby-wasm.js, ...) by bare relative name, so versioning the whole bundle
# dir — and pointing the iframe's <base href> at it (GamesController#game_assets_path)
# — busts stale browser/CDN caches on deploy without editing the vendored loader.
version = Digest::SHA256.file(ZIP).hexdigest[0, 12]
dest    = File.join(PUBLIC, version)

puts "== Refreshing #{PUBLIC} =="
FileUtils.rm_rf(PUBLIC)
FileUtils.mkdir_p(dest)

puts "== Unzipping into public/#{RAILS_ENV}_game_assets/#{version} =="
system! "unzip", "-o", "-q", ZIP, "-d", dest

# Sanity-check the layout, then drop the bundle's standalone index.html: the game
# is rendered inline by GamesController (app/views/games/show.html.erb loads the
# loader directly), so DragonRuby's own HTML page is unused.
index = File.join(dest, "index.html")
abort "index.html missing — check zip layout!" unless File.exist?(index)
FileUtils.rm_f(index)

# DragonRuby's HTML5 loader refuses to boot inside an <iframe> on Safari/Firefox,
# swapping the frame for a "Click Here to Load Game" link that escapes into the top
# window (its "only chrome works in iFrames" assumption predates Safari's
# SharedArrayBuffer support). We embed the game in a same-origin, cross-origin-isolated
# iframe on purpose (/game/frame inside /play), so disable that guard's browser check —
# every browser then takes the loader's normal loadLoadMainModule() path.
loader   = File.join(dest, "dragonruby-html5-loader.js")
original = File.read(loader)
guard    = "if (isSafari() || isMobileSafari() || isAndroid() || isNestedIFrame() || isFirefox()) {"
patched  = original.sub(guard, "if (false) { // authentication-hell: always boot inside our isolated iframe")
abort "Loader iframe guard not found — DragonRuby loader changed; re-check bin/build-game patch" if patched == original
File.write(loader, patched)
puts "== Patched loader to boot inside the iframe on all browsers =="

puts "== Done. Game assets in public/#{RAILS_ENV}_game_assets/#{version}/, Rails page at /play =="
