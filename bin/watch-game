#!/usr/bin/env ruby
require "listen"

APP_ROOT = File.expand_path("..", __dir__)
GAME_SRC = File.join(APP_ROOT, "game", "mygame")
BUILD    = File.join(APP_ROOT, "bin", "build-game")

def build!(reason)
  puts "== [watch-game] building (#{reason}) =="
  system(BUILD) || warn("== [watch-game] build failed; leaving previous bundle in place ==")
end

build!("initial")

# Watch only game/mygame/ (the source). Most build artifacts land in game/builds/
# and public/game_assets/, both outside mygame/. The exception is app/server_config.txt
# (the baked Rails port), which must live inside mygame/ to ship in the bundle —
# ignore it, or each build's rewrite would re-trigger the watcher in a loop.
listener = Listen.to(GAME_SRC, ignore: %r{app/server_config\.txt\z}) do |modified, added, removed|
  changed = (modified + added + removed).map { File.basename(it) }.join(", ")
  build!("changed: #{changed}")
end
listener.start
puts "== [watch-game] watching #{GAME_SRC} for changes =="
sleep
