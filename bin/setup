#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def command_exists?(command)
  system("command -v #{command} > /dev/null 2>&1")
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  # puts "\n== Copying sample files =="
  # unless File.exist?("config/database.yml")
  #   FileUtils.cp "config/database.yml.sample", "config/database.yml"
  # end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  # Keep the npm `playwright` package locked to the version playwright-ruby-client
  # expects, then install its browsers. Without this the Ruby client and the JS
  # CLI can disagree on the bundled browser revision and system tests fail to
  # launch. Skipped (with a warning) if npm isn't available.
  puts "\n== Installing Playwright (system tests) =="
  if command_exists?("npm")
    playwright_version = `bundle exec ruby -e 'require "playwright"; print Playwright::COMPATIBLE_PLAYWRIGHT_VERSION'`.strip
    if playwright_version.empty?
      warn "Could not determine the compatible Playwright version; skipping."
    else
      system! "npm", "install", "--save-dev", "--save-exact", "playwright@#{playwright_version}"
      system! "npx", "--yes", "playwright", "install", "chromium"
    end
  else
    warn "npm not found; skipping Playwright install. System tests need it (run bin/setup after installing npm)."
  end

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
